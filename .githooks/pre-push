#!/usr/bin/env bash

set -euo pipefail

fail=0

# Block pushing with active `[patch.*]` overrides in any tracked Cargo.toml.
while IFS= read -r file; do
  if grep -nE '^[[:space:]]*\\[patch\\.' "$file" >/dev/null; then
    echo "ERROR: [patch.*] sections found in $file:" >&2
    grep -nE '^[[:space:]]*\\[patch\\.' "$file" >&2 || true
    fail=1
  fi
done < <(git ls-files '*Cargo.toml')

if [ "$fail" -ne 0 ]; then
  echo "Fix: comment out or remove [patch.*] sections before pushing, and publish patched deps upstream first." >&2
  exit 1
fi

# Enforce vendoring only for SapienTeq microservice/site repos that ship `vendor.sh`.
if [ -f ./vendor.sh ]; then
  if [ ! -f ./.cargo/config.toml ]; then
    echo "ERROR: .cargo/config.toml not found. Vendoring must be configured; run ./vendor.sh." >&2
    exit 1
  fi

  if ! grep -qE 'replace-with\\s*=\\s*\"vendored-sources\"' ./.cargo/config.toml; then
    echo "ERROR: .cargo/config.toml does not configure replace-with = \"vendored-sources\"." >&2
    exit 1
  fi

  if [ ! -d ./vendor ]; then
    echo "ERROR: vendor/ directory not found. Run ./vendor.sh." >&2
    exit 1
  fi
fi


